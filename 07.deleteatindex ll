class Node {
    int data;
    Node next;

    Node(int data) {
        this.data = data;
        this.next = null;
    }
}

public class Main {

    // Display Linked List
    static void displayLinkedList(Node head) {

        Node temp = head;

        while (temp != null) {
            System.out.print(temp.data + " -> ");
            temp = temp.next;
        }

        System.out.println("null");
    }

    // Delete at Any Index
    static Node deleteAtIndex(Node head, int index) {

        // Delete first node
        if (index == 0) {
            return head.next;
        }

        Node temp = head;

        // Move to (index-1)th node
        for (int i = 1; i < index; i++) {
            temp = temp.next;
        }

        temp.next = temp.next.next;

        return head;
    }

    public static void main(String[] args) {

        Node a = new Node(10);
        Node b = new Node(20);
        Node c = new Node(30);
        Node d = new Node(40);

        a.next = b;
        b.next = c;
        c.next = d;

        Node head = a;

        System.out.println("Before Deletion:");
        displayLinkedList(head);

        head = deleteAtIndex(head, 2);

        System.out.println("After Deletion:");
        displayLinkedList(head);
    }
}
