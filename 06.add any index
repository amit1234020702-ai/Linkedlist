class Node {
    int data;
    Node next;

    Node(int data) {
        this.data = data;
        this.next = null;
    }
}

public class Main {

    // Display Linked List
    static void displayLinkedList(Node head) {
        Node temp = head;

        while (temp != null) {
            System.out.print(temp.data + " -> ");
            temp = temp.next;
        }

        System.out.println("null");
    }

    // Insert at Any Index
    static Node insertAtAnyIndex(Node head, int index, int value) {

        Node newNode = new Node(value);

        // Insert at beginning
        if (index == 0) {
            newNode.next = head;
            return newNode;
        }

        Node temp = head;

        // Move to (index-1)th node
        for (int i = 1; i < index; i++) {
            temp = temp.next;
        }

        newNode.next = temp.next;
        temp.next = newNode;

        return head;
    }

    public static void main(String[] args) {

        Node a = new Node(10);
        Node b = new Node(20);
        Node c = new Node(40);

        a.next = b;
        b.next = c;

        Node head = a;

        System.out.println("Before Insertion:");
        displayLinkedList(head);

        head = insertAtAnyIndex(head, 2, 30);

        System.out.println("After Insertion:");
        displayLinkedList(head);
    }
}
