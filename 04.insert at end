class Node {
    int data;
    Node next;

    Node(int data) {
        this.data = data;
        this.next = null;
    }
}

public class Main {

    // Display Linked List
    static void displayLinkedList(Node head) {
        Node temp = head;

        while (temp != null) {
            System.out.print(temp.data + " -> ");
            temp = temp.next;
        }

        System.out.println("null");
    }

    // Insert at End
    static Node insertAtEnd(Node head, int value) {

        Node newNode = new Node(value);

        // If Linked List is empty
        if (head == null) {
            return newNode;
        }

        Node temp = head;

        while (temp.next != null) {
            temp = temp.next;
        }

        temp.next = newNode;

        return head;
    }

    public static void main(String[] args) {

        Node a = new Node(10);
        Node b = new Node(20);
        Node c = new Node(30);

        a.next = b;
        b.next = c;

        Node head = a;

        System.out.println("Before Insertion:");
        displayLinkedList(head);

        head = insertAtEnd(head, 40);

        System.out.println("After Insertion:");
        displayLinkedList(head);
    }
}
